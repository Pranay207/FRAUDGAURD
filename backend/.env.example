# Copy this file to `backend/.env` or pass the same values through your deploy platform.
# These values are intentionally placeholders and will be flagged by `/v1/ops/security-posture`
# until you replace them with real secrets.
FRAUDGUARD_API_KEY=replace-with-strong-api-key
FRAUDGUARD_AUTH_SECRET=replace-with-a-strong-secret
FRAUDGUARD_DATABASE_URL=postgresql://fg:replace-with-db-password@postgres:5432/fraudguard
FRAUDGUARD_REDIS_URL=redis://redis:6379/0
FRAUDGUARD_AUDIT_LOG_PATH=/app/data/audit_logs.jsonl
FRAUDGUARD_MODEL_ARTIFACT_DIR=/app/data/models
FRAUDGUARD_TRAINING_DATA_DIR=/app/data/raw
